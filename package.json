{
  "name": "stabble-stellar-demo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "typecheck": "next typegen && tsc --noEmit",
    "precommit": "lint-staged && pnpm run lint && pnpm run typecheck",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "lint-staged": "^16.2.4",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "simple-git-hooks": {
    "pre-commit": "npx pnpm run precommit"
  },
  "lint-staged": {
    "*": "biome format --write --no-errors-on-unmatched"
  }
}
